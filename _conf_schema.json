{
  "default": {
    "description": "默认群配置",
    "hint": "这些配置项会作为默认群模板使用。具体群开启“跟随默认配置”后，会直接继承这里的设置；关闭后则保存自己的独立配置。",
    "obvious_hint": true,
    "type": "object",
    "items": {
      "plugin_enabled": {
        "description": "启用 QQ简单群管",
        "hint": "真实群聊的本地总开关。默认关闭；关闭时，本群不会响应群管命令，也不会执行禁词、刷屏、进群、退群等自动处理。默认模板不会控制这个开关，需要按真实群单独开启。",
        "type": "bool",
        "default": false
      },
      "join_switch": {
        "description": "进群审核",
        "hint": "开启后，本群会按白词、黑词、等级、尝试次数等规则处理进群申请；总黑名单、退群黑名单和进群黑名单会在插件启用后优先拦截。",
        "type": "bool",
        "default": true
      },
      "join_min_level": {
        "description": "进群等级门槛",
        "hint": "当申请人的QQ等级低于此值时，自动拒绝进群申请。设为0表示不启用此功能。可通过群内命令为当前群聊设置",
        "type": "int",
        "slider": {
          "min": 0,
          "max": 100,
          "step": 1
        },
        "default": 8
      },
      "join_max_time": {
        "description": "进群最大尝试次数",
        "hint": "当用户申请进行的次数超过此值时，自动拒绝进群申请。可通过群内命令为当前群聊设置",
        "type": "int",
        "slider": {
          "min": 0,
          "max": 10,
          "step": 1
        },
        "default": 3
      },
      "join_accept_words": {
        "description": "进群白词",
        "hint": "用户申请加群时, 若进群答案中包含这些关键词，则自动通过申请",
        "type": "list",
        "default": [
          "白词1",
          "白词2"
        ]
      },
      "join_reject_words": {
        "description": "进群黑词",
        "hint": "用户申请加群时, 若进群答案中包含这些关键词，则自动拒绝申请",
        "type": "list",
        "default": [
          "黑词1",
          "黑词2"
        ]
      },
      "join_no_match_reject": {
        "description": "自动拒绝未命中白词的进群申请",
        "hint": "当用户申请加群时，没命中进群关键词，则自动驳回申请",
        "type": "bool",
        "default": false
      },
      "reject_word_block": {
        "description": "命中进群黑词自动拉黑",
        "hint": "当用户因触发进群黑词而被拒绝进群时，自动拉黑该用户",
        "type": "bool",
        "default": false
      },
      "block_ids": {
        "description": "进群黑名单",
        "hint": "本群进群审核黑名单。命中进群黑词或超过进群尝试次数时会写入这里，只影响当前群。",
        "type": "list",
        "default": []
      },
      "leave_block_ids": {
        "description": "退群黑名单",
        "hint": "本群退群黑名单。用户主动退群并开启退群拉黑后会写入这里，只影响重新申请本群。",
        "type": "list",
        "default": []
      },
      "join_welcome": {
        "description": "进群欢迎词",
        "hint": "发给新群友的欢迎词，留空即关闭。支持变量：{nickname}，示例：欢迎{nickname}加入群聊",
        "type": "string",
        "default": ""
      },
      "join_ban_time": {
        "description": "进群禁言时长",
        "hint": "单位为秒，新成员进群时，自动禁言该成员",
        "type": "int",
        "slider": {
          "min": 0,
          "max": 300,
          "step": 10
        },
        "default": 0
      },
      "leave_notify": {
        "description": "主动退群通知",
        "hint": "当用户主动退群时，仅私发给主人QQ；不会向群内通报。",
        "type": "bool",
        "default": false
      },
      "leave_block": {
        "description": "主动退群拉黑",
        "hint": "当用户主动退群时，自动加入本群退群黑名单；该名单只拦截重新申请本群，不影响其他群。",
        "type": "bool",
        "default": false
      },
      "leave_block_reject_reason": {
        "description": "退群黑名单拒绝理由",
        "hint": "退群黑名单用户重新申请本群时使用的拒绝理由。支持变量：{group_id}、{user_id}。",
        "type": "string",
        "default": "你已被本群退群黑名单拦截"
      },
      "leave_notify_template": {
        "description": "退群通知模板",
        "hint": "支持变量：{group_name}、{group_id}、{nickname}、{user_id}、{block_status}。",
        "type": "text",
        "default": "【退群通知】群 {group_name}({group_id})\n{nickname}({user_id}) 主动退群了{block_status}"
      },
      "owner_ids": {
        "description": "主人QQ",
        "hint": "用于接收本群管理通知的QQ号列表。配置后，退群通知和总黑名单处理汇总会优先私聊这些主人QQ；未配置则回退到默认群主人QQ或 AstrBot 超管。",
        "type": "list",
        "default": []
      },
      "builtin_ban": {
        "description": "启用内置禁词",
        "hint": "插件内置了一个敏感词库, 如需自定义请自行修改：data/plugins/astrbot_plugin_qqmanager/SensitiveLexicon.json, 不建议开启，让群管理员通过命令“ 内置禁词 开/关 ”来为当前群聊设置",
        "type": "bool",
        "default": false
      },
      "custom_ban_words": {
        "description": "群内自定义的违禁词",
        "hint": "",
        "type": "list",
        "default": [
          "禁词1",
          "禁词2"
        ]
      },
      "word_ban_time": {
        "description": "触发禁词时的禁言时长",
        "hint": "触发违禁词则禁言发送者，单位：秒，设置为 0 表示不禁言",
        "type": "int",
        "slider": {
          "min": 0,
          "max": 600,
          "step": 60
        },
        "default": 360
      },
      "spamming_ban_time": {
        "description": "刷屏禁言时长（秒）",
        "hint": "当用户刷屏时触发禁言该用户，设置为 0 表示不启用此功能",
        "type": "int",
        "slider": {
          "min": 0,
          "max": 600,
          "step": 60
        },
        "default": 0
      }
    }
  },
  "admin_audit": {
    "description": "进群申请私信通知管理员",
    "hint": "默认关闭。开启后，收到进群申请或自动审核结果时，仅私信 AstrBot 超级管理员；关闭时不通知管理员，也不会发送到群聊。",
    "type": "bool",
    "default": false
  },
  "random_ban_time": {
    "description": "随机禁言配置",
    "hint": "若禁言命令未指定禁言时长，则使用随机时长，时长范围如下，单位为秒，用~表示范围",
    "type": "string",
    "default": "30~300"
  },
  "level_threshold": {
    "description": "高等级成员阈值设置",
    "hint": "群等级高于此阈值的群成员，将被判定为“高等级成员”",
    "type": "int",
    "slider": {
      "min": 1,
      "max": 100,
      "step": 1
    },
    "default": 50
  },
  "global_block_ids": {
    "description": "总黑名单",
    "hint": "全局 QQ 黑名单。命中后会拒绝加入任何已启用插件的群；通过插件设置页保存或使用“拉黑”命令新增时，会尝试从机器人加入的所有群中踢出该用户并私发汇总。",
    "type": "list",
    "default": []
  },
  "perms": {
    "description": "指令权限管理",
    "hint": "设置各个命令的使用权限。这里的“超管”来自 AstrBot 全局管理员 admins_id，不等同于本插件的主人QQ通知名单。",
    "type": "object",
    "items": {
      "set_group_ban": {
        "description": "禁言",
        "type": "string",
        "options": [
          "超管",
          "群主",
          "管理员",
          "高等级成员",
          "成员"
        ],
        "default": "超管"
      },
      "cancel_group_ban": {
        "description": "解禁",
        "type": "string",
        "options": [
          "超管",
          "群主",
          "管理员",
          "高等级成员",
          "成员"
        ],
        "default": "超管"
      },
      "set_group_kick": {
        "description": "踢",
        "type": "string",
        "options": [
          "超管",
          "群主",
          "管理员",
          "高等级成员",
          "成员"
        ],
        "default": "超管"
      },
      "set_group_block": {
        "description": "拉黑",
        "type": "string",
        "options": [
          "超管",
          "群主",
          "管理员",
          "高等级成员",
          "成员"
        ],
        "default": "超管"
      },
      "delete_msg": {
        "description": "撤回",
        "type": "string",
        "options": [
          "超管",
          "群主",
          "管理员",
          "高等级成员",
          "成员"
        ],
        "default": "超管"
      },
      "word_ban": {
        "description": "禁词指令",
        "hint": "包括：禁词禁言 <时长>、设置禁词、内置禁词 <开 | 关>",
        "type": "string",
        "options": [
          "超管",
          "群主",
          "管理员",
          "高等级成员",
          "成员"
        ],
        "default": "超管"
      },
      "spamming": {
        "description": "刷屏禁言指令",
        "hint": "包括：刷屏禁言",
        "type": "string",
        "options": [
          "超管",
          "群主",
          "管理员",
          "高等级成员",
          "成员"
        ],
        "default": "超管"
      },
      "curfew": {
        "description": "宵禁指令",
        "hint": "包括开启宵禁、关闭宵禁",
        "type": "string",
        "options": [
          "超管",
          "群主",
          "管理员",
          "高等级成员",
          "成员"
        ],
        "default": "超管"
      },
      "join": {
        "description": "进群审核指令",
        "hint": "进群审核相关功能包括：进群审核开关、进群白词、进群黑词、进群等级、进群尝试次数、未命中白词自动拒绝、命中黑词拉黑、进群黑名单",
        "type": "string",
        "options": [
          "超管",
          "群主",
          "管理员",
          "高等级成员",
          "成员"
        ],
        "default": "超管"
      },
      "approve": {
        "description": "批准/驳回（进群申请）",
        "type": "string",
        "options": [
          "超管",
          "群主",
          "管理员",
          "高等级成员",
          "成员"
        ],
        "default": "超管"
      },
      "welcome": {
        "description": "进群欢迎与禁言",
        "hint": "",
        "type": "string",
        "options": [
          "超管",
          "群主",
          "管理员",
          "高等级成员",
          "成员"
        ],
        "default": "超管"
      },
      "leave": {
        "description": "退群通知与拉黑",
        "hint": "",
        "type": "string",
        "options": [
          "超管",
          "群主",
          "管理员",
          "高等级成员",
          "成员"
        ],
        "default": "超管"
      },
      "get_group_member_list": {
        "description": "群友信息",
        "type": "string",
        "options": [
          "超管",
          "群主",
          "管理员",
          "高等级成员",
          "成员"
        ],
        "default": "超管"
      },
      "set_config": {
        "description": "群管配置",
        "type": "string",
        "options": [
          "超管",
          "群主",
          "管理员",
          "高等级成员",
          "成员"
        ],
        "default": "超管"
      },
      "reset_config": {
        "description": "群管重置",
        "type": "string",
        "options": [
          "超管",
          "群主",
          "管理员",
          "高等级成员",
          "成员"
        ],
        "default": "超管"
      }
    }
  }
}

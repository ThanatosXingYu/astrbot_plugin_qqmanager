{
  "default": {
    "description": "默认群配置",
    "hint": "这些配置项会作为默认群模板使用。具体群开启“跟随默认配置”后，会直接继承这里的设置；关闭后则保存自己的独立配置。",
    "obvious_hint": true,
    "type": "object",
    "items": {
      "join_switch": {
        "description": "进群审核",
        "hint": "开启后，进群退群模块的功能才会在当前群聊生效，群主、群管理可用命令 “进群审核 开/关” 为当前群聊设置",
        "type": "bool",
        "default": true
      },
      "join_min_level": {
        "description": "进群等级门槛",
        "hint": "当申请人的QQ等级低于此值时，自动拒绝进群申请。设为0表示不启用此功能。可通过群内命令为当前群聊设置",
        "type": "int",
        "slider": {
          "min": 0,
          "max": 100,
          "step": 1
        },
        "default": 8
      },
      "join_max_time": {
        "description": "进群最大尝试次数",
        "hint": "当用户申请进行的次数超过此值时，自动拒绝进群申请。可通过群内命令为当前群聊设置",
        "type": "int",
        "slider": {
          "min": 0,
          "max": 10,
          "step": 1
        },
        "default": 3
      },
      "join_accept_words": {
        "description": "进群白词",
        "hint": "用户申请加群时, 若进群答案中包含这些关键词，则自动通过申请",
        "type": "list",
        "default": [
          "白词1",
          "白词2"
        ]
      },
      "join_reject_words": {
        "description": "进群黑词",
        "hint": "用户申请加群时, 若进群答案中包含这些关键词，则自动拒绝申请",
        "type": "list",
        "default": [
          "黑词1",
          "黑词2"
        ]
      },
      "join_no_match_reject": {
        "description": "自动拒绝未命中白词的进群申请",
        "hint": "当用户申请加群时，没命中进群关键词，则自动驳回申请",
        "type": "bool",
        "default": false
      },
      "reject_word_block": {
        "description": "命中进群黑词自动拉黑",
        "hint": "当用户因触发进群黑词而被拒绝进群时，自动拉黑该用户",
        "type": "bool",
        "default": false
      },
      "block_ids": {
        "description": "进群黑名单",
        "hint": "用户加入群聊时，若用户QQ在黑名单中，则自动拒绝",
        "type": "list",
        "default": []
      },
      "join_welcome": {
        "description": "进群欢迎词",
        "hint": "发给新群友的欢迎词, 支持变量: {nickname}, 示例：欢迎{nickname}加入群聊",
        "type": "string",
        "default": ""
      },
      "join_ban_time": {
        "description": "进群禁言时长",
        "hint": "单位为秒，新成员进群时，自动禁言该成员",
        "type": "int",
        "slider": {
          "min": 0,
          "max": 300,
          "step": 10
        },
        "default": 0
      },
      "leave_notify": {
        "description": "主动退群通知",
        "hint": "当用户主动退群时，向群内通报",
        "type": "bool",
        "default": false
      },
      "leave_block": {
        "description": "主动退群拉黑",
        "hint": "当用户主动退群时，自动拉黑（即添加到进群黑名单）",
        "type": "bool",
        "default": false
      },
      "owner_ids": {
        "description": "主人QQ",
        "hint": "用于接收本群管理通知的QQ号列表。配置后，退群通知会优先私聊这些主人QQ；未配置则按原逻辑发到群内。",
        "type": "list",
        "default": []
      },
      "builtin_ban": {
        "description": "启用内置禁词",
        "hint": "插件内置了一个敏感词库, 如需自定义请自行修改：data/plugins/astrbot_plugin_qqmanager/SensitiveLexicon.json, 不建议开启，让群管理员通过命令“ 内置禁词 开/关 ”来为当前群聊设置",
        "type": "bool",
        "default": false
      },
      "custom_ban_words": {
        "description": "群内自定义的违禁词",
        "hint": "",
        "type": "list",
        "default": [
          "禁词1",
          "禁词2"
        ]
      },
      "word_ban_time": {
        "description": "触发禁词时的禁言时长",
        "hint": "触发违禁词则禁言发送者，单位：秒，设置为 0 表示不禁言",
        "type": "int",
        "slider": {
          "min": 0,
          "max": 600,
          "step": 60
        },
        "default": 360
      },
      "spamming_ban_time": {
        "description": "刷屏禁言时长（秒）",
        "hint": "当用户刷屏时触发禁言该用户，设置为 0 表示不启用此功能",
        "type": "int",
        "slider": {
          "min": 0,
          "max": 600,
          "step": 60
        },
        "default": 0
      }
    }
  },
  "admin_audit": {
    "description": "进群事件仅通知bot管理员",
    "hint": "如果开启，则进群事件仅通知bot管理员，不再将通知发送在对应群聊",
    "type": "bool",
    "default": false
  },
  "random_ban_time": {
    "description": "随机禁言配置",
    "hint": "若禁言命令未指定禁言时长，则使用随机时长，时长范围如下，单位为秒，用~表示范围",
    "type": "string",
    "default": "30~300"
  },
  "level_threshold": {
    "description": "高等级成员阈值设置",
    "hint": "群等级高于此阈值的群成员，将被判定为“高等级成员”",
    "type": "int",
    "slider": {
      "min": 1,
      "max": 100,
      "step": 1
    },
    "default": 50
  },
